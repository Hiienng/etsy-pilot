# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=your_secret_key_here

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://nguyenphamdieuhien.online

# ─── Git ─────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_token_here
